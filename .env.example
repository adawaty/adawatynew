# ─────────────────────────────────────────────────────────────
#  Adawaty — environment variables
#  Copy to .env.local for local development
# ─────────────────────────────────────────────────────────────

# Neon Postgres connection string (server-side only — never expose to browser)
# Get it from: https://console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://username:password@ep-xxx-yyy.us-east-2.aws.neon.tech/neondb?sslmode=require

# Optional: pooler URL for Vercel serverless (recommended for production)
# DATABASE_URL_POOLER=postgresql://username:password@ep-xxx-yyy-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# Admin dashboard token — used to protect /admin and /api/admin/* routes
# Set a long random string. Example: openssl rand -hex 32
ADMIN_TOKEN=change_me_to_a_long_random_string

# ─────────────────────────────────────────────────────────────
#  Neon project info (for GitHub Actions preview branches)
#  Repository variable: NEON_PROJECT_ID=calm-moon-05727272
#  Repository secret:   NEON_API_KEY=<your Neon API key>
# ─────────────────────────────────────────────────────────────
