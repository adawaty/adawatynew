# ── Neon Postgres ─────────────────────────────────────────────────────────────
# Get from your Neon project dashboard → Connection details → Connection string
# Use the pooled connection string (recommended for serverless)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Optional: use the pooler URL explicitly (falls back to DATABASE_URL if unset)
# DATABASE_URL_POOLER=postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true

# ── Admin dashboard ────────────────────────────────────────────────────────────
# Set a strong, random secret — paste this into /admin on the live site to log in
ADMIN_TOKEN=change-me-use-a-strong-random-secret

# ── GitHub Actions / Neon preview branches (CI only) ──────────────────────────
# Add these as GitHub repository variable / secret, not in .env.local
# NEON_PROJECT_ID=calm-moon-05727272   ← repo variable
# NEON_API_KEY=<your neon api key>     ← repo secret
